    "-extensions\\handoff\\index.ts",
    "-extensions\\pi-subagent\\index.ts",
    "-extensions\\prompt-stash.ts",
    "-extensions\\session-query\\index.ts",
    "-extensions\\tab-status\\index.ts",
    "-extensions\\theme-cycle\\index.ts",
